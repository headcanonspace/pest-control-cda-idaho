Options -MultiViews
RewriteEngine On
RewriteBase /

# Explicit directory rewrites to prevent DirectorySlash listings
RewriteRule ^services/?$ services.html [NC,L]
RewriteRule ^locations/?$ locations.html [NC,L]
RewriteRule ^blog/?$ blog.html [NC,L]


# 1. Force clean URLs (redirect any direct .html requests to clean URLs)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Redirect trailing slashes for non-directories (canonicalization)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# 3. Internally rewrite clean URLs to their corresponding .html files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# 4. Internally rewrite clean URLs to their corresponding .php files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]
